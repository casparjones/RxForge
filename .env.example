DATABASE_URL=postgresql://rxforge:rxforge@localhost:5432/rxforge
COUCHDB_URL=http://localhost:5984
COUCHDB_USER=admin
COUCHDB_PASSWORD=password
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
SERVER_PORT=8080
FRONTEND_DIR=./dist
RUST_LOG=info

# Public domain shown in the login screen status bar
PUBLIC_APP_DOMAIN=rxforge.de

# Optional: if set, registration requires this invite code
# REGISTER_INVITE_CODE=your-secret-invite-code

# Optional: user with this email is auto-promoted to admin on login
# ADMIN_USER_EMAIL=admin@example.com
